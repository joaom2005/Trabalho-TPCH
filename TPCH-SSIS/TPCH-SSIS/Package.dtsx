                  name="SqlCommandParam"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">select * from (select * from [dbo].[DimClient]) [refTable]
where [refTable].[SourceCustomerKey] = ?</property>
                <property
