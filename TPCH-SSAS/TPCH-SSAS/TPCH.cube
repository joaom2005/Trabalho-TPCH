  <MdxScripts>
    <MdxScript dwd:design-time-name="7b4aad1e-71cf-48e1-aa98-724997ba40b0">
      <ID>MdxScript</ID>
      <Name>MdxScript</Name>
      <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
      <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
      <Commands>
        <Command>
          <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
If the CALCULATE command is deleted or modified, the data within the cube is affected.
You should edit this command only if you manually specify how the cube is aggregated.
*/
CALCULATE; 
CREATE MEMBER CURRENTCUBE.[Measures].[Net Revenue]
 AS [Measures].[SalesAmount] - [Measures].[Discount], 
FORMAT_STRING = "Currency", 
VISIBLE = 1  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[Profit]
 AS [Measures].[Net Revenue] - [Measures].[Cost], 
FORMAT_STRING = "Currency", 
VISIBLE = 1  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[Margin]
 AS [Measures].[Profit] / [Measures].[Net Revenue], 
FORMAT_STRING = "Percent", 
VISIBLE = 1  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[Gross Revenue]
 AS [Measures].[SalesAmount], 
FORMAT_STRING = "Currency", 
VISIBLE = 1  ; </Text>
        </Command>
      </Commands>
    </MdxScript>
  </MdxScripts>
</Cube>